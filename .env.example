# Скопируй этот файл в .env и заполни своими значениями
# cp .env.example .env

# Токен Telegram-бота (получить у @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Твой Telegram user_id (узнать у @userinfobot)
TELEGRAM_ADMIN_ID=123456789

# Логин и пароль для веб-панели администратора
WEB_LOGIN=admin
WEB_PASSWORD=your_strong_password_here

# Секретный ключ Flask (случайная строка, минимум 32 символа)
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate_a_random_secret_key_here

# Порт Flask (для Railway/Heroku задаётся автоматически)
PORT=5000
